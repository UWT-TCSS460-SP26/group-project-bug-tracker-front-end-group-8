# Base URL the Next.js rewrite proxies to.
# The browser calls /api/issues and Next forwards it to ${NEXT_PUBLIC_API_URL}/v1/issues.
# Uncomment one of the two depending on what you want to hit during `npm run dev`.

# Deployed BE on Render (default):
NEXT_PUBLIC_API_URL=https://tcss460-team-8-api.onrender.com

# Local BE on your laptop (swap with the line above when running the BE locally):
# NEXT_PUBLIC_API_URL=http://localhost:8000
